NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/academy_management
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
CLIENT_URL=http://localhost:5173
REDIS_URL=redis://127.0.0.1:6379
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
FIREBASE_SERVICE_ACCOUNT_PATH=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Default admin (created/ensured on every server start if missing)
SEED_ADMIN_EMAIL=admin@academy.local
SEED_ADMIN_PASSWORD=Admin@123456
SEED_ADMIN_NAME=System Admin
SEED_ADMIN_PHONE=00000000000
# SEED_ADMIN_RESET_PASSWORD=true
