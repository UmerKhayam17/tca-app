# Frontend environment (Vite)
# Copy to `.env` and restart `npm run dev`.

# Backend API origin (no trailing slash, no /api/v1 suffix).
# All REST calls use: ${VITE_API_URL}/api/v1/...
VITE_API_URL=http://127.0.0.1:5000

# Socket.io server origin (no path). Used for chat and real-time updates.
VITE_SOCKET_URL=http://127.0.0.1:5000

# Production example:
# VITE_API_URL=https://api.yourdomain.com
# VITE_SOCKET_URL=https://api.yourdomain.com
